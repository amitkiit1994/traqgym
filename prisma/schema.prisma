generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Location {
  id        Int      @id @default(autoincrement())
  name      String
  code      String   @unique
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  users            User[]
  workers          Worker[]
  memberTickets    MemberTicket[]
  payments         Payment[]
  attendanceLogs   AttendanceLog[]
  biometricDevices BiometricDevice[]
  openingHours     OpeningHour[]
  expenses         Expense[]
  announcements    Announcement[]
  equipment        Equipment[]
  enquiries        Enquiry[]
  classes          GymClass[]
  lockers          Locker[]
  cashShifts       CashShift[]
}

model User {
  id         Int       @id @default(autoincrement())
  email      String    @unique
  password   String
  firstname  String
  lastname   String
  phone      String?
  gender     String?
  birthdate  DateTime?
  locationId Int?
  location   Location? @relation(fields: [locationId], references: [id])
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())

  memberTickets      MemberTicket[]
  payments           Payment[]
  attendanceLogs     AttendanceLog[]
  notifications      NotificationLog[]
  invoices           Invoice[]
  deviceMappings     DeviceUserMapping[]
  freezes            MembershipFreeze[]
  bodyMeasurements   BodyMeasurement[]
  referralsGiven     Referral[]            @relation("referrals_given")
  referralsReceived  Referral[]            @relation("referrals_received")
  classBookings      ClassBooking[]
  paymentFollowups   PaymentFollowup[]
  familyGroupId      Int?
  familyGroup        FamilyGroup?          @relation(fields: [familyGroupId], references: [id])
  waiverSignatures   WaiverSignature[]
  facilityBookings   FacilityBooking[]
  userWorkoutPlans   UserWorkoutPlan[]
  userDietPlans      UserDietPlan[]
  inAppNotifications InAppNotification[]   @relation("UserInAppNotifications")
  extensions         MembershipExtension[]
  lockers            Locker[]
  feedbacks          Feedback[]
  appointments       Appointment[]
  compPasses         CompPass[]
  lockerKeyIssuances LockerKeyIssuance[]
  alternatePhone     String?
  address            String?
  occupation         String?
  anniversaryDate    DateTime?
  govtId             String?
  ptPackages         PtPackage[]
  gstin              String? // optional B2B customer GSTIN for GSTR-1 export

  @@index([phone])
  @@index([locationId])
  @@index([birthdate])
}

model Worker {
  id         Int       @id @default(autoincrement())
  email      String    @unique
  password   String
  firstname  String
  lastname   String
  role       String    @default("staff")
  locationId Int?
  location   Location? @relation(fields: [locationId], references: [id])
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())

  isExternal       Boolean @default(false)
  defaultGymCutPct Decimal @default(0) @db.Decimal(5, 2)
  ownTrainerCutPct Decimal @default(0) @db.Decimal(5, 2)

  paymentsCollected   Payment[]
  attendanceLogs      AttendanceLog[]
  deviceMappings      DeviceUserMapping[]
  leaveRequests       LeaveRequest[]
  classes             GymClass[]
  followupAssignments PaymentFollowup[]   @relation("FollowupAssignee")
  enquiryFollowups    EnquiryFollowup[]   @relation("EnquiryFollowupWorker")
  payrolls            Payroll[]
  createdWorkoutPlans WorkoutPlan[]
  createdDietPlans    DietPlan[]
  inAppNotifications  InAppNotification[] @relation("WorkerInAppNotifications")
  appointments        Appointment[]
  compApprovedTickets MemberTicket[]      @relation("CompApprovedTickets")
  compIssuedTickets   MemberTicket[]      @relation("CompIssuedTickets")
  compPassesIssued    CompPass[]          @relation("CompPassIssuer")
  compPassesApproved  CompPass[]          @relation("CompPassApprover")
  compPassesRevoked   CompPass[]          @relation("CompPassRevoker")
  insightsDismissed   Insight[]           @relation("InsightDismisser")
  approvalsRequested  Approval[]          @relation("ApprovalRequester")
  approvalsDecided    Approval[]          @relation("ApprovalDecider")
  ptPackagesAsTrainer PtPackage[]         @relation("PtPackageTrainer")
  trainerPayments     Payment[]           @relation("PaymentTrainer")
  trainerPayouts      TrainerPayout[]     @relation("TrainerPayout")
  refundsRequested    Refund[]            @relation("RefundRequester")
  refundsApproved     Refund[]            @relation("RefundApprover")
  shiftsOpened        CashShift[]         @relation("ShiftOpener")
  shiftsClosed        CashShift[]         @relation("ShiftCloser")
  shiftsApproved      CashShift[]         @relation("ShiftApprover")
  feedbacksAsTrainer  Feedback[]          @relation("FeedbackTrainer")
  keysIssued          LockerKeyIssuance[] @relation("KeyIssuer")
  keysReturned        LockerKeyIssuance[] @relation("KeyReturner")
  keyWitnessed        LockerKeyIssuance[] @relation("KeyWitness")
}

model TicketPlan {
  id                  Int      @id @default(autoincrement())
  name                String
  expireDays          Int
  price               Decimal  @db.Decimal(10, 2)
  occasions           Int?
  isActive            Boolean  @default(true)
  isTrial             Boolean  @default(false)
  trialDays           Int?
  joiningFee          Decimal  @default(0) @db.Decimal(10, 2)
  joiningFeeAppliesOn String   @default("first_only") // first_only, every_renewal, never
  createdAt           DateTime @default(now())

  memberTickets MemberTicket[]
}

model MemberTicket {
  id                Int        @id @default(autoincrement())
  userId            Int
  user              User       @relation(fields: [userId], references: [id], onDelete: Restrict)
  planId            Int
  plan              TicketPlan @relation(fields: [planId], references: [id], onDelete: Restrict)
  locationId        Int?
  location          Location?  @relation(fields: [locationId], references: [id], onDelete: SetNull)
  buyDate           DateTime   @default(now())
  expireDate        DateTime
  occasions         Int?
  renewedBy         Int?
  status            String     @default("active") // active, cancelled
  cancelledAt       DateTime?
  isTrial           Boolean    @default(false)
  totalAmount       Decimal?   @db.Decimal(10, 2)
  amountPaid        Decimal    @default(0) @db.Decimal(10, 2)
  balanceDue        Decimal    @default(0) @db.Decimal(10, 2)
  joiningFeeCharged Decimal    @default(0) @db.Decimal(10, 2)
  dueDate           DateTime?
  createdAt         DateTime   @default(now())

  externalRef String?

  isComplimentary       Boolean   @default(false)
  compReason            String?
  compApprovedById      Int?
  compApprover          Worker?   @relation("CompApprovedTickets", fields: [compApprovedById], references: [id], onDelete: SetNull)
  compIssuedById        Int?
  compIssuer            Worker?   @relation("CompIssuedTickets", fields: [compIssuedById], references: [id], onDelete: SetNull)
  compExpiresAt         DateTime?
  compConvertedToPaidAt DateTime?

  payments          Payment[]
  freezes           MembershipFreeze[]
  extensions        MembershipExtension[]
  compPassConverted CompPass[]            @relation("CompPassConvertedTicket")
  paymentSchedule   PaymentSchedule?
  refunds           Refund[]

  @@index([userId, expireDate])
  @@index([locationId, expireDate])
  @@index([status, balanceDue])
  @@index([planId])
  @@index([isComplimentary, status])
}

model Payment {
  id                Int           @id @default(autoincrement())
  // userId/memberTicketId are nullable so POS sales (walk-ins, no member
  // ticket) can also be expressed as Payment rows for cashflow + drawer
  // reconciliation. Member-bound payments (renewals, PT, freezes, etc.)
  // continue to set both fields.
  userId            Int?
  user              User?         @relation(fields: [userId], references: [id], onDelete: Restrict)
  memberTicketId    Int?
  memberTicket      MemberTicket? @relation(fields: [memberTicketId], references: [id], onDelete: Restrict)
  locationId        Int?
  location          Location?     @relation(fields: [locationId], references: [id], onDelete: SetNull)
  amount            Decimal       @db.Decimal(10, 2)
  paymentMode       String
  upiReference      String?
  paymentNote       String?
  collectedById     Int
  collectedBy       Worker        @relation(fields: [collectedById], references: [id], onDelete: Restrict)
  oldExpiryDate     DateTime?
  newExpiryDate     DateTime?
  baseAmount        Decimal?      @db.Decimal(10, 2)
  taxRate           Decimal?      @db.Decimal(5, 2)
  taxAmount         Decimal?      @db.Decimal(10, 2)
  paymentStatus     String        @default("full") // full, partial, advance
  chequeNumber      String?
  chequeDate        DateTime?
  chequeStatus      String? // pending, cleared, bounced
  bankName          String?
  razorpayOrderId   String?
  razorpayPaymentId String?
  discount          Decimal?      @db.Decimal(10, 2)
  paymentFor        String?
  createdAt         DateTime      @default(now())

  trainerId Int?
  trainer   Worker?    @relation("PaymentTrainer", fields: [trainerId], references: [id], onDelete: SetNull)
  shiftId   Int?
  shift     CashShift? @relation("ShiftPayment", fields: [shiftId], references: [id], onDelete: SetNull)

  invoice             Invoice?
  ptPackages          PtPackage[]
  installmentPayments PaymentInstallment[]
  refunds             Refund[]
  sale                Sale?

  @@index([createdAt])
  @@index([locationId, createdAt])
  @@index([collectedById])
  @@index([paymentMode, createdAt])
  @@index([shiftId])
}

model Invoice {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  paymentId     Int      @unique
  payment       Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoiceNumber String   @unique
  route         String
  status        String   @default("paid")
  createdAt     DateTime @default(now())

  refunds Refund[]
}

model AttendanceLog {
  id             Int       @id @default(autoincrement())
  userId         Int?
  user           User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workerId       Int?
  worker         Worker?   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  locationId     Int
  location       Location  @relation(fields: [locationId], references: [id], onDelete: Restrict)
  attendanceDate DateTime  @db.Date
  checkIn        DateTime
  checkOut       DateTime?
  source         String    @default("manual")
  sourceEventId  Int?
  deviceId       Int?
  notes          String?
  isLateEntry    Boolean   @default(false)
  isPeakHours    Boolean   @default(false)
  scanSource     String? // qr_lobby, biometric, manual, etc.
  createdAt      DateTime  @default(now())

  @@unique([userId, locationId, attendanceDate], name: "uk_member_daily")
  @@unique([workerId, locationId, attendanceDate], name: "uk_worker_daily")
  @@index([attendanceDate])
  @@index([locationId, attendanceDate])
  @@index([userId, attendanceDate])
}

model BiometricDevice {
  id           Int       @id @default(autoincrement())
  name         String
  locationId   Int
  location     Location  @relation(fields: [locationId], references: [id])
  deviceType   String    @default("fingerprint")
  csvFormat    String    @default("default")
  csvDelimiter String    @default(",")
  timezone     String    @default("Asia/Kolkata")
  lastSyncAt   DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())

  syncRuns     BiometricSyncRun[]
  rawEvents    RawAttendanceEvent[]
  userMappings DeviceUserMapping[]
}

model BiometricSyncRun {
  id               Int             @id @default(autoincrement())
  deviceId         Int
  device           BiometricDevice @relation(fields: [deviceId], references: [id])
  fileName         String?
  fileHash         String?
  runType          String          @default("manual")
  status           String          @default("running")
  totalRecords     Int             @default(0)
  matchedRecords   Int             @default(0)
  unmatchedRecords Int             @default(0)
  duplicateRecords Int             @default(0)
  errorLog         String?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime        @default(now())

  rawEvents RawAttendanceEvent[]
}

model RawAttendanceEvent {
  id              Int               @id @default(autoincrement())
  syncRunId       Int?
  syncRun         BiometricSyncRun? @relation(fields: [syncRunId], references: [id])
  deviceId        Int
  device          BiometricDevice   @relation(fields: [deviceId], references: [id])
  deviceUserId    String
  eventTimestamp  DateTime
  eventType       String            @default("check_in")
  rawData         String?
  matchStatus     String            @default("unmatched")
  matchedUserId   Int?
  matchedWorkerId Int?
  createdAt       DateTime          @default(now())

  @@unique([deviceId, deviceUserId, eventTimestamp])
}

model DeviceUserMapping {
  id           Int             @id @default(autoincrement())
  deviceId     Int
  device       BiometricDevice @relation(fields: [deviceId], references: [id])
  deviceUserId String
  userId       Int?
  user         User?           @relation(fields: [userId], references: [id])
  workerId     Int?
  worker       Worker?         @relation(fields: [workerId], references: [id])
  createdAt    DateTime        @default(now())

  @@unique([deviceId, deviceUserId])
}

model NotificationLog {
  id           Int       @id @default(autoincrement())
  userId       Int
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateName String
  channel      String
  recipient    String?
  status       String    @default("pending")
  errorMessage String?
  deliveryDate DateTime  @db.Date
  sentAt       DateTime?
  readAt       DateTime?
  createdAt    DateTime  @default(now())

  @@unique([userId, templateName, deliveryDate])
}

model OpeningHour {
  id         Int      @id @default(autoincrement())
  locationId Int
  location   Location @relation(fields: [locationId], references: [id])
  dayOfWeek  Int
  openTime   String
  closeTime  String
  isClosed   Boolean  @default(false)
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String
  status    String
  details   String?
  actorId   Int?
  actorType String?
  createdAt DateTime @default(now())
}

model MembershipFreeze {
  id             Int          @id @default(autoincrement())
  userId         Int
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  memberTicketId Int
  memberTicket   MemberTicket @relation(fields: [memberTicketId], references: [id], onDelete: Cascade)
  freezeStart    DateTime     @db.Date
  freezeEnd      DateTime     @db.Date
  reason         String?
  status         String       @default("active") // active, completed, cancelled
  daysAdded      Int          @default(0)
  originalExpiry DateTime?
  createdAt      DateTime     @default(now())
}

model BodyMeasurement {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date       DateTime @db.Date
  weight     Decimal? @db.Decimal(5, 2)
  height     Decimal? @db.Decimal(5, 2)
  bmi        Decimal? @db.Decimal(5, 2)
  chest      Decimal? @db.Decimal(5, 2)
  waist      Decimal? @db.Decimal(5, 2)
  hips       Decimal? @db.Decimal(5, 2)
  biceps     Decimal? @db.Decimal(5, 2)
  notes      String?
  recordedBy Int?
  createdAt  DateTime @default(now())
}

model LeaveRequest {
  id         Int       @id @default(autoincrement())
  workerId   Int
  worker     Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)
  leaveType  String    @default("casual") // casual, sick, personal
  startDate  DateTime  @db.Date
  endDate    DateTime  @db.Date
  reason     String?
  status     String    @default("pending") // pending, approved, rejected
  reviewedBy Int?
  reviewedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([status])
}

model GymSettings {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model Enquiry {
  id              Int       @id @default(autoincrement())
  name            String
  phone           String
  email           String?
  source          String    @default("walk_in")
  interest        String?
  locationId      Int?
  location        Location? @relation(fields: [locationId], references: [id])
  status          String    @default("new")
  followUpDate    DateTime? @db.Date
  notes           String?
  assignedTo      Int?
  convertedUserId Int?
  stage           String    @default("new") // new, contacted, tour_scheduled, tour_done, trial, negotiation, converted, lost
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  prospectType   String?
  referredByName String?

  followups EnquiryFollowup[]

  @@index([status])
}

model PromoCode {
  id            Int      @id @default(autoincrement())
  code          String   @unique
  discountType  String   @default("percentage")
  discountValue Decimal  @db.Decimal(10, 2)
  maxUses       Int?
  usedCount     Int      @default(0)
  validFrom     DateTime @db.Date
  validTo       DateTime @db.Date
  isActive      Boolean  @default(true)
  planIds       String?
  createdAt     DateTime @default(now())
}

model Referral {
  id            Int      @id @default(autoincrement())
  referrerId    Int
  referrer      User     @relation("referrals_given", fields: [referrerId], references: [id])
  referredId    Int?
  referred      User?    @relation("referrals_received", fields: [referredId], references: [id])
  referredName  String
  referredPhone String
  status        String   @default("pending")
  rewardGiven   Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model Expense {
  id          Int       @id @default(autoincrement())
  category    String // rent, salary, equipment, maintenance, utilities, marketing, other
  description String
  amount      Decimal   @db.Decimal(10, 2)
  expenseDate DateTime  @db.Date
  locationId  Int?
  location    Location? @relation(fields: [locationId], references: [id])
  paidBy      String? // cash, upi, bank_transfer
  receipt     String? // receipt reference
  recordedBy  Int?
  createdAt   DateTime  @default(now())
}

model Announcement {
  id          Int       @id @default(autoincrement())
  title       String
  content     String
  priority    String    @default("normal") // low, normal, high, urgent
  targetGroup String    @default("all") // all, members, staff
  locationId  Int?
  location    Location? @relation(fields: [locationId], references: [id])
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdBy   Int?
  createdAt   DateTime  @default(now())

  @@index([isActive, targetGroup])
}

model Equipment {
  id              Int       @id @default(autoincrement())
  name            String
  category        String // cardio, strength, free_weights, accessories, other
  locationId      Int
  location        Location  @relation(fields: [locationId], references: [id])
  purchaseDate    DateTime? @db.Date
  purchasePrice   Decimal?  @db.Decimal(10, 2)
  condition       String    @default("good") // good, fair, needs_repair, out_of_service
  lastServiceDate DateTime? @db.Date
  nextServiceDate DateTime? @db.Date
  notes           String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
}

model GymClass {
  id           Int      @id @default(autoincrement())
  name         String
  description  String?
  classType    String   @default("group") // group, personal_training, workshop
  instructorId Int?
  instructor   Worker?  @relation(fields: [instructorId], references: [id])
  locationId   Int
  location     Location @relation(fields: [locationId], references: [id])
  maxCapacity  Int      @default(20)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  schedules ClassSchedule[]
  bookings  ClassBooking[]
}

model ClassSchedule {
  id        Int      @id @default(autoincrement())
  classId   Int
  gymClass  GymClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  dayOfWeek Int // 0=Sunday, 1=Monday, ..., 6=Saturday
  startTime String // "07:00"
  endTime   String // "08:00"
  createdAt DateTime @default(now())

  feedbacks Feedback[]
}

model ClassBooking {
  id           Int      @id @default(autoincrement())
  classId      Int
  gymClass     GymClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduleDate DateTime @db.Date
  status       String   @default("booked") // booked, cancelled, attended, no_show
  createdAt    DateTime @default(now())

  @@unique([classId, userId, scheduleDate])
}

model GymTarget {
  id               Int      @id @default(autoincrement())
  month            Int
  year             Int
  targetRevenue    Decimal  @db.Decimal(12, 2)
  targetNewMembers Int      @default(0)
  targetRenewals   Int      @default(0)
  locationId       Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([month, year, locationId])
}

model AiConversation {
  id             Int         @id @default(autoincrement())
  workerId       Int
  title          String?
  channel        String      @default("web") // web | email | telegram | system
  // PR 9: Telegram channel pairing.
  telegramChatId String? // when channel = "telegram"
  telegramUserId String? // for outbound DM (optional)
  // PR 9 (also used by PR 16): detected language for the conversation.
  detectedLang   String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  messages       AiMessage[]

  @@unique([channel, telegramChatId], name: "AiConversation_channel_telegramChatId_key")
}

model AiMessage {
  id             Int            @id @default(autoincrement())
  conversationId Int
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  toolName       String?
  toolCallId     String?
  createdAt      DateTime       @default(now())
}

model AiUsage {
  id         Int      @id @default(autoincrement())
  workerId   Int
  month      String
  queryCount Int      @default(0)
  createdAt  DateTime @default(now())

  @@unique([workerId, month])
}

model PaymentFollowup {
  id              Int       @id @default(autoincrement())
  userId          Int
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  memberTicketId  Int?
  amountDue       Decimal   @db.Decimal(10, 2)
  dueDate         DateTime
  assignedToId    Int?
  assignedTo      Worker?   @relation("FollowupAssignee", fields: [assignedToId], references: [id])
  status          String    @default("pending") // pending, contacted, promised, resolved, written_off
  priority        String    @default("normal") // low, normal, high, critical
  notes           String?
  lastContactedAt DateTime?
  nextFollowupAt  DateTime?
  resolvedAt      DateTime?
  callSubject     String?
  reason          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
}

model EnquiryFollowup {
  id             Int       @id @default(autoincrement())
  enquiryId      Int
  enquiry        Enquiry   @relation(fields: [enquiryId], references: [id], onDelete: Cascade)
  workerId       Int
  worker         Worker    @relation("EnquiryFollowupWorker", fields: [workerId], references: [id])
  action         String // call, visit, whatsapp, email, sms, demo
  outcome        String // interested, not_interested, no_answer, callback, visited, converted
  notes          String?
  nextFollowupAt DateTime?
  createdAt      DateTime  @default(now())
}

// ─── Gift Cards ───

model GiftCard {
  id             Int       @id @default(autoincrement())
  code           String    @unique
  amount         Decimal   @db.Decimal(10, 2)
  balance        Decimal   @db.Decimal(10, 2)
  purchaserId    Int?
  recipientName  String?
  recipientPhone String?
  status         String    @default("active") // active, redeemed, expired
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
}

// ─── Digital Waivers ───

model WaiverTemplate {
  id         Int               @id @default(autoincrement())
  name       String
  content    String
  isActive   Boolean           @default(true)
  required   Boolean           @default(true)
  createdAt  DateTime          @default(now())
  signatures WaiverSignature[]
}

model WaiverSignature {
  id         Int            @id @default(autoincrement())
  userId     Int
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId Int
  template   WaiverTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  signedAt   DateTime       @default(now())
  ipAddress  String?
  signature  String?

  @@unique([userId, templateId])
}

// ─── Payroll ───

model Payroll {
  id         Int       @id @default(autoincrement())
  workerId   Int
  worker     Worker    @relation(fields: [workerId], references: [id])
  month      Int
  year       Int
  baseSalary Decimal   @db.Decimal(10, 2)
  commission Decimal   @default(0) @db.Decimal(10, 2)
  deductions Decimal   @default(0) @db.Decimal(10, 2)
  bonus      Decimal   @default(0) @db.Decimal(10, 2)
  netPayable Decimal   @db.Decimal(10, 2)
  status     String    @default("pending") // pending, processed, paid
  paidAt     DateTime?
  createdAt  DateTime  @default(now())

  @@unique([workerId, month, year])
}

// ─── Family/Group Accounts ───

model FamilyGroup {
  id              Int      @id @default(autoincrement())
  name            String
  primaryMemberId Int
  createdAt       DateTime @default(now())
  members         User[]
}

// ─── POS / Retail ───

model Product {
  id            Int            @id @default(autoincrement())
  name          String
  price         Decimal        @db.Decimal(10, 2)
  stock         Int            @default(0)
  category      String         @default("general")
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  sales         Sale[]
  inventoryLogs InventoryLog[]
}

model Sale {
  id          Int        @id @default(autoincrement())
  productId   Int
  product     Product    @relation(fields: [productId], references: [id])
  quantity    Int
  unitPrice   Decimal    @db.Decimal(10, 2)
  totalAmount Decimal    @db.Decimal(10, 2)
  userId      Int?
  paymentMode String     @default("cash")
  locationId  Int?
  soldById    Int?
  // H6 — link to the universal Payment ledger so cashflow + reports include
  // POS sales. 1:1 because each Sale produces exactly one Payment row.
  paymentId   Int?       @unique
  payment     Payment?   @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  // H7 — tag to the open CashShift at the seller's location so cash sales
  // reconcile against the drawer in closeShift().
  shiftId     Int?
  shift       CashShift? @relation("ShiftSale", fields: [shiftId], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())

  @@index([shiftId])
  @@index([locationId, createdAt])
}

model InventoryLog {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  change    Int // positive = restock, negative = sale/loss
  reason    String // sale, restock, adjustment, loss
  createdAt DateTime @default(now())
}

// ─── Facility Bookings ───

model Facility {
  id         Int            @id @default(autoincrement())
  name       String
  type       String // court, pool, studio, track
  locationId Int?
  isActive   Boolean        @default(true)
  createdAt  DateTime       @default(now())
  slots      FacilitySlot[]
}

model FacilitySlot {
  id          Int               @id @default(autoincrement())
  facilityId  Int
  facility    Facility          @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  date        DateTime          @db.Date
  startTime   String // "07:00"
  endTime     String // "08:00"
  maxCapacity Int               @default(1)
  status      String            @default("available") // available, full, blocked
  createdAt   DateTime          @default(now())
  bookings    FacilityBooking[]

  @@unique([facilityId, date, startTime])
}

model FacilityBooking {
  id        Int          @id @default(autoincrement())
  slotId    Int
  slot      FacilitySlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  userId    Int
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    String       @default("booked") // booked, cancelled, completed
  createdAt DateTime     @default(now())

  @@unique([slotId, userId])
}

// ─── Workout & Diet Plans ───

model WorkoutPlan {
  id          Int               @id @default(autoincrement())
  name        String
  description String?
  createdById Int
  createdBy   Worker            @relation(fields: [createdById], references: [id])
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  exercises   WorkoutExercise[]
  assignments UserWorkoutPlan[]
}

model WorkoutExercise {
  id     Int         @id @default(autoincrement())
  planId Int
  plan   WorkoutPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  name   String
  sets   Int         @default(3)
  reps   Int         @default(12)
  weight Float?
  day    String // "monday", "tuesday", etc.
  order  Int         @default(0)
  notes  String?
}

model UserWorkoutPlan {
  id        Int         @id @default(autoincrement())
  userId    Int
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId    Int
  plan      WorkoutPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  startDate DateTime    @default(now())
  endDate   DateTime?
  isActive  Boolean     @default(true)

  @@unique([userId, planId])
}

model DietPlan {
  id          Int            @id @default(autoincrement())
  name        String
  description String?
  createdById Int
  createdBy   Worker         @relation(fields: [createdById], references: [id])
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  meals       DietMeal[]
  assignments UserDietPlan[]
}

model DietMeal {
  id          Int      @id @default(autoincrement())
  planId      Int
  plan        DietPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  mealType    String // breakfast, lunch, dinner, snack
  description String
  calories    Int?
  protein     Float?
  carbs       Float?
  fat         Float?
  order       Int      @default(0)
}

model UserDietPlan {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId    Int
  plan      DietPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  startDate DateTime  @default(now())
  endDate   DateTime?
  isActive  Boolean   @default(true)

  @@unique([userId, planId])
}

model InAppNotification {
  id        Int       @id @default(autoincrement())
  userId    Int?
  user      User?     @relation("UserInAppNotifications", fields: [userId], references: [id], onDelete: Cascade)
  workerId  Int?
  worker    Worker?   @relation("WorkerInAppNotifications", fields: [workerId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String?
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt, createdAt])
  @@index([workerId, readAt, createdAt])
}

// ─── AI Proactive Features ───

model AiProactiveLog {
  id         Int      @id @default(autoincrement())
  feature    String // daily_briefing, churn_alert, lead_followup, member_nudge, weekly_summary, milestone
  targetType String // "worker" | "user"
  targetId   Int
  channel    String // "whatsapp" | "in_app" | "both"
  content    String
  tokensUsed Int?
  status     String   @default("sent") // sent | failed | skipped
  error      String?
  createdAt  DateTime @default(now())

  @@index([feature, createdAt])
  @@index([targetType, targetId, createdAt])
}

model MembershipExtension {
  id             Int          @id @default(autoincrement())
  userId         Int
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  memberTicketId Int
  memberTicket   MemberTicket @relation(fields: [memberTicketId], references: [id], onDelete: Cascade)
  daysAdded      Int
  reason         String
  originalExpiry DateTime
  newExpiry      DateTime
  createdById    Int
  createdAt      DateTime     @default(now())

  @@index([userId])
  @@index([memberTicketId])
}

model Locker {
  id         Int       @id @default(autoincrement())
  number     String
  locationId Int
  location   Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  status     String    @default("available") // available, assigned, maintenance
  assignedTo Int?
  user       User?     @relation(fields: [assignedTo], references: [id], onDelete: SetNull)
  assignedAt DateTime?
  notes      String?
  createdAt  DateTime  @default(now())

  keyIssuances LockerKeyIssuance[]

  @@unique([number, locationId])
  @@index([locationId, status])
}

model Feedback {
  id        Int            @id @default(autoincrement())
  userId    Int
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int // 1-5
  comment   String?
  category  String? // facility, trainer, cleanliness, general, class
  classId   Int?
  class     ClassSchedule? @relation(fields: [classId], references: [id], onDelete: SetNull)
  trainerId Int?
  trainer   Worker?        @relation("FeedbackTrainer", fields: [trainerId], references: [id], onDelete: SetNull)
  createdAt DateTime       @default(now())

  @@index([userId, createdAt])
  @@index([trainerId, createdAt])
  @@index([classId, createdAt])
}

model Appointment {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainerId Int
  trainer   Worker   @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  startTime String
  endTime   String
  status    String   @default("booked") // booked, completed, cancelled, no_show
  notes     String?
  createdAt DateTime @default(now())

  @@unique([trainerId, date, startTime])
  @@index([userId, date])
}

// ─── Complimentary access (informal "I let him in" passes — distinct from MemberTicket.isComplimentary which models comp on a real plan) ───
model CompPass {
  id                Int           @id @default(autoincrement())
  userId            Int
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason            String // money_crunch, trial, influencer, family, compensation, owner_friend, legacy_zero_payment, other
  reasonDetail      String?
  startsAt          DateTime      @default(now())
  expiresAt         DateTime
  issuedById        Int
  issuedBy          Worker        @relation("CompPassIssuer", fields: [issuedById], references: [id], onDelete: Restrict)
  approvedById      Int?
  approvedBy        Worker?       @relation("CompPassApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  status            String        @default("active") // active, expired, revoked, converted
  convertedTicketId Int?
  convertedTicket   MemberTicket? @relation("CompPassConvertedTicket", fields: [convertedTicketId], references: [id], onDelete: SetNull)
  revokedAt         DateTime?
  revokedById       Int?
  revokedBy         Worker?       @relation("CompPassRevoker", fields: [revokedById], references: [id], onDelete: SetNull)
  revokeReason      String?
  notes             String?
  createdAt         DateTime      @default(now())

  @@index([status, expiresAt])
  @@index([userId, status])
  @@index([issuedById])
}

// ─── AI agent insights (proactive findings — comp auditor, silent churn, etc.) ───
model Insight {
  id               Int       @id @default(autoincrement())
  agent            String // "comp_auditor", "silent_churn", etc.
  severity         String // "critical", "high", "medium", "low"
  title            String
  body             String    @db.Text
  dataJson         Json?
  suggestedActions Json? // [{label, action, args}]
  entityType       String? // "user", "worker", "ticket", "enquiry", "global"
  entityId         Int?
  dedupeKey        String    @unique
  dismissedAt      DateTime?
  dismissedById    Int?
  dismissedBy      Worker?   @relation("InsightDismisser", fields: [dismissedById], references: [id], onDelete: SetNull)
  snoozedUntil     DateTime?
  ownerSeenAt      DateTime?
  // PR 16 K.1: fatigue dedup — when the manager last surfaced this insight in
  // a briefing. Used to suppress repeats inside `manager_min_repeat_hours`.
  lastNotifiedAt   DateTime?
  createdAt        DateTime  @default(now())

  // PR 16 K.4: cross-channel delivery tracking (email + telegram message_ids).
  deliveries InsightDelivery[]

  @@index([agent, createdAt])
  @@index([severity, dismissedAt])
  // Sprint 3 perf: every dashboard load + manager briefing filters by
  // `dismissedAt IS NULL` + `snoozedUntil < now()`. Without this composite
  // index Postgres falls back to a sequential scan once the table grows past
  // a few thousand rows. Most rows carry NULL on both columns so the index
  // also stays small.
  @@index([dismissedAt, snoozedUntil])
}

// ─── Refund workflow ───
model Refund {
  id                Int           @id @default(autoincrement())
  paymentId         Int
  payment           Payment       @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  invoiceId         Int?
  invoice           Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  memberTicketId    Int?
  memberTicket      MemberTicket? @relation(fields: [memberTicketId], references: [id], onDelete: SetNull)
  amountRequested   Decimal       @db.Decimal(10, 2)
  amountRefunded    Decimal       @default(0) @db.Decimal(10, 2)
  refundMode        String // cash | upi | bank_transfer | adjust_against_next_plan
  reason            String // quit | dissatisfied | duplicate_charge | medical | gym_closure | other
  reasonDetail      String?
  status            String        @default("pending") // pending, approved, processed, rejected, failed
  requestedById     Int
  requestedBy       Worker        @relation("RefundRequester", fields: [requestedById], references: [id], onDelete: Restrict)
  approvedById      Int?
  approvedBy        Worker?       @relation("RefundApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt        DateTime?
  processedAt       DateTime?
  pgRefundId        String?
  gstReversalAmount Decimal?      @db.Decimal(10, 2)
  proRataDays       Int?
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([status, createdAt])
  @@index([paymentId])
}

// ─── Cash shift management (per-location end-of-day reconciliation) ───
model CashShift {
  id              Int       @id @default(autoincrement())
  locationId      Int
  location        Location  @relation(fields: [locationId], references: [id], onDelete: Restrict)
  openedById      Int
  openedBy        Worker    @relation("ShiftOpener", fields: [openedById], references: [id], onDelete: Restrict)
  openedAt        DateTime  @default(now())
  openingFloat    Decimal   @db.Decimal(10, 2)
  closedById      Int?
  closedBy        Worker?   @relation("ShiftCloser", fields: [closedById], references: [id], onDelete: SetNull)
  closedAt        DateTime?
  closingExpected Decimal?  @db.Decimal(10, 2)
  closingCounted  Decimal?  @db.Decimal(10, 2)
  variance        Decimal?  @db.Decimal(10, 2)
  varianceReason  String?
  status          String    @default("open") // open, pending_approval, closed, voided
  approvedById    Int?
  approvedBy      Worker?   @relation("ShiftApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt      DateTime?
  notes           String?

  payments  Payment[]           @relation("ShiftPayment")
  sales     Sale[]              @relation("ShiftSale")
  movements CashShiftMovement[]

  @@index([locationId, status])
  @@index([openedAt])
}

model CashShiftMovement {
  id          Int       @id @default(autoincrement())
  shiftId     Int
  shift       CashShift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  type        String // float_topup, cash_withdrawal, expense, deposit_to_bank
  amount      Decimal   @db.Decimal(10, 2)
  reason      String
  createdById Int
  createdAt   DateTime  @default(now())

  @@index([shiftId, createdAt])
}

// ─── Universal approval queue (comp, freeze, extension, refund, discount, ...) ───
model Approval {
  id            Int       @id @default(autoincrement())
  type          String // "comp", "comp_pass", "freeze", "extension", "refund", "discount_over_threshold"
  entityType    String // "MemberTicket", "CompPass", "MembershipFreeze", "MembershipExtension", "Payment"
  entityId      Int? // null until the entity is created (deferred-create approvals)
  payloadJson   Json // params to apply on approval
  status        String    @default("pending") // pending, approved, rejected, expired, cancelled
  requestedById Int
  requestedBy   Worker    @relation("ApprovalRequester", fields: [requestedById], references: [id], onDelete: Restrict)
  decidedById   Int?
  decidedBy     Worker?   @relation("ApprovalDecider", fields: [decidedById], references: [id], onDelete: SetNull)
  decidedAt     DateTime?
  decisionNote  String?
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())

  @@index([status, type])
  @@index([requestedById])
  @@index([entityType, entityId])
}

// ─── Personal Training (PT) ───

model PtPackage {
  id              Int       @id @default(autoincrement())
  userId          Int
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainerId       Int
  trainer         Worker    @relation("PtPackageTrainer", fields: [trainerId], references: [id], onDelete: Restrict)
  paymentId       Int?
  payment         Payment?  @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  sessionsTotal   Int
  sessionsUsed    Int       @default(0)
  pricePerSession Decimal   @db.Decimal(10, 2)
  totalPrice      Decimal   @db.Decimal(10, 2)
  trainerSharePct Decimal   @default(0) @db.Decimal(5, 2)
  startedAt       DateTime  @default(now())
  expiresAt       DateTime?
  status          String    @default("active") // active, completed, expired, cancelled
  createdAt       DateTime  @default(now())

  sessions PtSession[]

  @@index([userId, status])
  @@index([trainerId, status])
}

model PtSession {
  id          Int       @id @default(autoincrement())
  packageId   Int
  package     PtPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  scheduledAt DateTime
  completedAt DateTime?
  status      String    @default("scheduled") // scheduled, completed, no_show, cancelled
  notes       String?
  createdAt   DateTime  @default(now())

  @@index([packageId, status])
}

model TrainerPayout {
  id            Int       @id @default(autoincrement())
  trainerId     Int
  trainer       Worker    @relation("TrainerPayout", fields: [trainerId], references: [id], onDelete: Restrict)
  periodStart   DateTime
  periodEnd     DateTime
  sessionsCount Int
  grossRevenue  Decimal   @db.Decimal(12, 2)
  gymShare      Decimal   @db.Decimal(12, 2)
  trainerShare  Decimal   @db.Decimal(12, 2)
  paidAt        DateTime?
  paymentMode   String?
  status        String    @default("pending") // pending, paid, cancelled
  createdAt     DateTime  @default(now())

  @@unique([trainerId, periodStart, periodEnd])
}

// ─── Payment Schedules / Installment Plans ───

model PaymentSchedule {
  id             Int          @id @default(autoincrement())
  memberTicketId Int          @unique
  memberTicket   MemberTicket @relation(fields: [memberTicketId], references: [id], onDelete: Cascade)
  totalAmount    Decimal      @db.Decimal(10, 2)
  status         String       @default("active") // active, completed, defaulted, cancelled
  createdById    Int
  createdAt      DateTime     @default(now())

  installments PaymentInstallment[]

  @@index([status])
}

model PaymentInstallment {
  id             Int             @id @default(autoincrement())
  scheduleId     Int
  schedule       PaymentSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  sequenceNumber Int
  dueDate        DateTime
  amount         Decimal         @db.Decimal(10, 2)
  paidAmount     Decimal         @default(0) @db.Decimal(10, 2)
  paidAt         DateTime?
  paymentId      Int?
  payment        Payment?        @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  status         String          @default("pending") // pending, paid, overdue, waived
  reminderSentAt DateTime?

  @@unique([scheduleId, sequenceNumber])
  @@index([dueDate, status])
}

model LockerKeyIssuance {
  id                Int                 @id @default(autoincrement())
  lockerId          Int
  locker            Locker              @relation(fields: [lockerId], references: [id], onDelete: Cascade)
  userId            Int
  user              User                @relation(fields: [userId], references: [id], onDelete: Restrict)
  issuedAt          DateTime            @default(now())
  issuedById        Int
  issuedBy          Worker              @relation("KeyIssuer", fields: [issuedById], references: [id], onDelete: Restrict)
  expectedReturnAt  DateTime?
  returnedAt        DateTime?
  returnedById      Int?
  returnedBy        Worker?             @relation("KeyReturner", fields: [returnedById], references: [id], onDelete: SetNull)
  depositAmount     Decimal             @db.Decimal(10, 2)
  depositRefundedAt DateTime?
  conditionNotes    String?
  status            String              @default("issued") // issued, returned, lost, forfeited
  penaltyAmount     Decimal             @default(0) @db.Decimal(10, 2)
  photoUrl          String?
  witnessId         Int?
  witness           Worker?             @relation("KeyWitness", fields: [witnessId], references: [id], onDelete: SetNull)
  parentIssuanceId  Int?
  parentIssuance    LockerKeyIssuance?  @relation("KeyReissue", fields: [parentIssuanceId], references: [id], onDelete: SetNull)
  reissues          LockerKeyIssuance[] @relation("KeyReissue")
  createdAt         DateTime            @default(now())

  @@index([userId, status])
  @@index([status, expectedReturnAt])
  @@index([lockerId, status])
}

// ─── PR 16 K.4: per-channel delivery log for cross-channel sync ───
// One row per (insight, channel) delivery. Lets us, after an action is taken
// via channel A, locate the original message in channel B and edit it to
// reflect the new state ("Done via email").
model InsightDelivery {
  id                Int      @id @default(autoincrement())
  insightId         Int
  insight           Insight  @relation(fields: [insightId], references: [id], onDelete: Cascade)
  channel           String // "email" | "telegram"
  recipient         String? // email address OR telegram chat id
  telegramChatId    String?
  telegramMessageId Int?
  sentAt            DateTime @default(now())

  @@index([insightId])
  @@index([channel, sentAt])
}

model ProcessedTelegramUpdate {
  updateId    BigInt   @id // Telegram update_id is a 64-bit integer
  processedAt DateTime @default(now())

  @@index([processedAt])
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  email     String // not unique — can have multiple active tokens (last one wins for verification)
  tokenHash String    @unique // sha256 of the actual token; we never store the raw value
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([expiresAt])
}

// ─── Phase 6a: prospect-facing gym signup intake ────────────────────────────
// Rows are inserted by the public /signup form. Ops review the queue and
// provision approved entries via `scripts/onboard-gym.sh`.
model PendingGymProvisioning {
  id            Int       @id @default(autoincrement())
  gymName       String
  ownerName     String
  ownerEmail    String
  ownerPhone    String
  subdomain     String? // requested (we'll validate uniqueness during provisioning)
  city          String?
  notes         String?
  status        String    @default("pending") // pending | approved | provisioned | rejected
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  provisionedAt DateTime?
  provisionedBy String?

  @@index([status])
  @@index([createdAt])
}
