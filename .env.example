# TraqGym environment variables — copy to .env.local for development.

# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/traqgym?schema=public

# ─── NextAuth ──────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-please-use-openssl-rand-base64-32

# ─── Branding (defaults; can be overridden in Settings UI) ─────────────────
NEXT_PUBLIC_GYM_NAME=TraqGym

# ─── Cron auth ─────────────────────────────────────────────────────────────
CRON_SECRET=

# ─── AI / OpenAI ───────────────────────────────────────────────────────────
# Optional: when set, manager briefing intro + per-section paragraphs are
# humanised by an LLM. When empty, a deterministic template is used (zero cost).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── PR 8: Manager email briefing ──────────────────────────────────────────
# HMAC secret used to sign magic-link action URLs sent in the morning briefing.
# Falls back to a derived value from NEXTAUTH_SECRET when unset (with warning).
# Generate with: `openssl rand -base64 32`
MANAGER_ACTION_SECRET=

# ─── PR 14: QR self-check-in ───────────────────────────────────────────────
# HMAC-SHA256 secret used to sign lobby QR tokens. Generate with: openssl rand -hex 32
# WARNING: rotating this invalidates all printed lobby posters.
QR_TOKEN_SECRET=

# ─── SMTP (email channel) ──────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── MSG91 (WhatsApp + SMS) ────────────────────────────────────────────────
MSG91_AUTH_KEY=
MSG91_WHATSAPP_NUMBER=
MSG91_SMS_FLOW_ID=
MSG91_SMS_SENDER_ID=

# ─── Razorpay (optional) ───────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
