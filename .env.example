# TraqGym environment variables — copy to .env.local for development.

# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/traqgym?schema=public

# ─── NextAuth ──────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-please-use-openssl-rand-base64-32

# ─── Secret encryption (required for production) ──────────────────────────
# AES-256-GCM key used to encrypt sensitive GymSettings values
# (SMTP/MSG91/Telegram/v3-fitnessboard credentials). Generate with:
#   openssl rand -base64 32
DATA_ENCRYPTION_KEY=

# ─── Branding (defaults; can be overridden in Settings UI) ─────────────────
NEXT_PUBLIC_GYM_NAME=TraqGym

# ─── Cron auth ─────────────────────────────────────────────────────────────
CRON_SECRET=

# ─── AI / OpenAI ───────────────────────────────────────────────────────────
# Optional: when set, manager briefing intro + per-section paragraphs are
# humanised by an LLM. When empty, a deterministic template is used (zero cost).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── PR 8: Manager email briefing ──────────────────────────────────────────
# HMAC secret used to sign magic-link action URLs sent in the morning briefing.
# Falls back to a derived value from NEXTAUTH_SECRET when unset (with warning).
# Generate with: `openssl rand -base64 32`
MANAGER_ACTION_SECRET=

# ─── PR 14: QR self-check-in ───────────────────────────────────────────────
# HMAC-SHA256 secret used to sign lobby QR tokens. Generate with: openssl rand -hex 32
# WARNING: rotating this invalidates all printed lobby posters.
QR_TOKEN_SECRET=

# ─── SMTP (email channel) ──────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── MSG91 (WhatsApp + SMS) ────────────────────────────────────────────────
MSG91_AUTH_KEY=
MSG91_WHATSAPP_NUMBER=
MSG91_SMS_FLOW_ID=
MSG91_SMS_SENDER_ID=

# ─── Razorpay (optional) ───────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── PR 9: Telegram bot (outbound briefing + AI replies + voice) ───────────
# Single global bot serves all gym instances. Get the token from @BotFather.
TELEGRAM_BOT_TOKEN=
# Username (without @) used in pairing instructions on the Settings page.
TELEGRAM_BOT_USERNAME=
# Random secret token Telegram echoes back in the
# X-Telegram-Bot-Api-Secret-Token header on every webhook POST. Generate with
# `openssl rand -hex 32`. Settings UI value (telegram_webhook_secret) wins.
TELEGRAM_WEBHOOK_SECRET=
# OpenAI Whisper API key for transcribing voice notes. Falls back to
# OPENAI_API_KEY if unset. Voice notes are skipped (with a friendly message)
# when neither is configured.
WHISPER_API_KEY=
WHISPER_MODEL=whisper-1
